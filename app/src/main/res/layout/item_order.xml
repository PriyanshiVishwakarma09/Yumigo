<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp">

    <!-- Top row: truck image + details + price -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Truck image -->
        <ImageView
            android:id="@+id/img_vehicle"
            android:layout_width="55dp"
            android:layout_height="45dp"
            android:src="@drawable/ic_truck"
            android:scaleType="fitCenter"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="2dp"
            android:contentDescription="Vehicle" />

        <!-- Middle details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Vehicle type -->
            <TextView
                android:id="@+id/tv_vehicle_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Four Wheeler"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <!-- Date and Order ID -->
            <TextView
                android:id="@+id/tv_date_order_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="05 Feb, 4:46 PM | Order ID: #ORD12345"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Price -->
        <TextView
            android:id="@+id/tv_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹ 229.0"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <!-- Three dot menu -->
        <ImageView
            android:id="@+id/btn_more"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_more_vert"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginStart="4dp"
            android:contentDescription="More options" />
    </LinearLayout>

    <!-- Pickup location -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp"
        android:layout_marginStart="67dp">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_green" />

        <TextView
            android:id="@+id/tv_pickup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="741, Gumanwara"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Drop location -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:layout_marginStart="67dp">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_red"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tv_drop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="00, Main Rd, Shivaji Nagar, Jhansi, Uttar Pradesh 284001, India"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="40dp" />
    </LinearLayout>

    <!-- Status + Buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp">

        <!-- Status badge -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CANCELLED"
            android:textColor="@color/status_cancelled_text"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_status_cancelled"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Invoice button -->
        <LinearLayout
            android:id="@+id/btn_invoice"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_button_outline_ripple"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginEnd="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_download"
                android:layout_marginEnd="4dp"
                android:contentDescription="Download" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/invoice"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Book Again button -->
        <LinearLayout
            android:id="@+id/btn_book_again"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_button_outline_ripple"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/book_again"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="14dp" />

</LinearLayout>
